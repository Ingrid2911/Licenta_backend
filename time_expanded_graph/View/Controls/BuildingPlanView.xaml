<UserControl x:Class="time_expanded_graph.View.Controls.BuildingPlanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <!-- Stil paletă definit LOCAL pentru a nu depinde de Style.xaml global -->
        <Style x:Key="PaletteBtn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stil ToggleButton paletă -->
        <Style x:Key="ConnectToggleBtn" TargetType="ToggleButton">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#37474F"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="15"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F57C00"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#1A2028">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Bara de instrumente -->
        <Border Grid.Row="0"
                Background="#202B35"
                Padding="8,6"
                BorderBrush="#3A4A5A"
                BorderThickness="0,0,0,1">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="Adaugă:"
                           Foreground="#AAB8C2"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>

                <Button x:Name="BtnAddStart"
                        Content="▶ Start"
                        Style="{StaticResource PaletteBtn}"
                        Background="#2E7D32"
                        Click="BtnAddStart_Click"
                        ToolTip="Punct de start — sursa persoanelor"/>
                <Button x:Name="BtnAddRoom"
                        Content="▣ Cameră"
                        Style="{StaticResource PaletteBtn}"
                        Background="#455A64"
                        Click="BtnAddRoom_Click"
                        ToolTip="Cameră / încăpere"/>
                <Button x:Name="BtnAddStairs"
                        Content="⬆ Scări"
                        Style="{StaticResource PaletteBtn}"
                        Background="#1565C0"
                        Click="BtnAddStairs_Click"
                        ToolTip="Scări (timp traversare 2 u.t.)"/>

                <Button x:Name="BtnAddElevator"
                        Content="⊞ Lift"
                        Style="{StaticResource PaletteBtn}"
                        Background="#6A1B9A"
                        Click="BtnAddElevator_Click"
                        ToolTip="Lift (timp traversare 3 u.t.)"/>

                <Button x:Name="BtnAddExit"
                        Content="🚨 Ieșire"
                        Style="{StaticResource PaletteBtn}"
                        Background="#E65100"
                        Click="BtnAddExit_Click"
                        ToolTip="Ușă de evacuare — destinația"/>

                <Separator Width="1" Height="24" Margin="8,0"
                           Background="#3A4A5A"/>

                <ToggleButton x:Name="BtnConnectMode"
                              Content="🔗 Conectează (Hol)"
                              Style="{StaticResource ConnectToggleBtn}"
                              Checked="BtnConnectMode_Checked"
                              Unchecked="BtnConnectMode_Unchecked"
                              ToolTip="Click pe doi noduri pentru a-i conecta"/>

                <Separator Width="1" Height="24" Margin="8,0"
                           Background="#3A4A5A"/>

                <Button x:Name="BtnClear"
                        Content="🗑 Curăță"
                        Style="{StaticResource PaletteBtn}"
                        Background="#B71C1C"
                        Click="BtnClear_Click"/>

                <Button x:Name="BtnBuildGraph"
                        Content="⚡ Construiește Graf"
                        Style="{StaticResource PaletteBtn}"
                        Background="#00695C"
                        Click="BtnBuildGraph_Click"
                        ToolTip="Convertește planul și rulează algoritmii"/>

                <TextBlock x:Name="StatusText"
                           Text="Adaugă elemente din paletă, apoi conectează-le."
                           Foreground="#78909C"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
                <Button x:Name="BtnSavePlan"
        Content="💾 Salvează"
        Style="{StaticResource PaletteBtn}"
        Background="#455A64"
        Click="BtnSavePlan_Click"/>

                <Button x:Name="BtnLoadPlan"
        Content="📂 Încarcă"
        Style="{StaticResource PaletteBtn}"
        Background="#455A64"
        Click="BtnLoadPlan_Click"/>

            </WrapPanel>
        </Border>

        <!-- Canvas + Legendă -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <!-- Canvas principal -->
            <Border Grid.Column="0"
                    Background="#1C2730"
                    BorderBrush="#2A3A4A"
                    BorderThickness="1"
                    Margin="4">
                <Canvas x:Name="PlanCanvas"
                        Background="Transparent"
                        ClipToBounds="True"/>
            </Border>

            <!-- Legendă -->
            <Border Grid.Column="1"
                    Background="#202B35"
                    Padding="12"
                    Margin="0,4,4,4">
                <StackPanel>
                    <TextBlock Text="LEGENDĂ"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,8"
                               HorizontalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <Ellipse Width="14" Height="14" Fill="#4CAF50" Margin="0,0,6,0"/>
                        <TextBlock Text="Start" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <Ellipse Width="14" Height="14" Fill="#FF9800" Margin="0,0,6,0"/>
                        <TextBlock Text="Ieșire evacuare" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <Ellipse Width="14" Height="14" Fill="#607D8B" Margin="0,0,6,0"/>
                        <TextBlock Text="Ușă internă" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <Ellipse Width="14" Height="14" Fill="#2196F3" Margin="0,0,6,0"/>
                        <TextBlock Text="Scări" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <Ellipse Width="14" Height="14" Fill="#9C27B0" Margin="0,0,6,0"/>
                        <TextBlock Text="Lift" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Separator Margin="0,6" Background="#3A4A5A"/>

                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <Rectangle Width="18" Height="3" Fill="#64B4FF" Margin="0,5,6,0"/>
                        <TextBlock Text="Hol" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <Rectangle Width="18" Height="4" Fill="Red" Margin="0,5,6,0"/>
                        <TextBlock Text="Drum optim" Foreground="#FF6060" FontSize="11"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Separator Margin="0,6" Background="#3A4A5A"/>

                    <TextBlock Text="💡 Cum folosești:"
                               Foreground="#78909C"
                               FontSize="10"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="1. Adaugă elementele"
                               Foreground="#546E7A" FontSize="10" TextWrapping="Wrap" Margin="0,2"/>
                    <TextBlock Text="2. Trage să le poziționezi"
                               Foreground="#546E7A" FontSize="10" TextWrapping="Wrap" Margin="0,2"/>
                    <TextBlock Text="3. Activează 🔗 și conectează noduri"
                               Foreground="#546E7A" FontSize="10" TextWrapping="Wrap" Margin="0,2"/>
                    <TextBlock Text="4. Setează parametrii (dreapta)"
                               Foreground="#546E7A" FontSize="10" TextWrapping="Wrap" Margin="0,2"/>
                    <TextBlock Text="5. Apasă ⚡ Construiește Graf"
                               Foreground="#546E7A" FontSize="10" TextWrapping="Wrap" Margin="0,2"/>
                    <TextBlock Text="Click dreapta = opțiuni nod"
                               Foreground="#546E7A" FontSize="10" TextWrapping="Wrap" Margin="0,6,0,0"
                               FontStyle="Italic"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
