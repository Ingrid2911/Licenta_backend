<UserControl x:Class="time_expanded_graph.View.Controls.GraphTabsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:time_expanded_graph.View.Controls">

    <TabControl Background="#2C3943">

        <!-- TAB 1: Plan Clădire (NOU) -->
        <TabItem Header="Plan Clădire">
            <local:BuildingPlanView x:Name="BuildingPlan"/>
        </TabItem>

        <!-- TAB 2: Graf original (debug) -->
        <TabItem Header="Graf original">
            <Canvas x:Name="OriginalGraphCanvas"
                    Background="#202B33"/>
        </TabItem>

        <!-- TAB 3: Time-expanded -->
        <TabItem Header="Time-expanded">
            <Canvas x:Name="ExpandedGraphCanvas"
                    Background="#202B33"/>
        </TabItem>

        <!-- TAB 4: Dinic -->
        <TabItem Header="Dinic">
            <Canvas x:Name="DinicGraphCanvas"
                    Background="#202B33"/>
        </TabItem>

        <!-- TAB 5: Push-Relabel -->
        <TabItem Header="Push-Relabel">
            <Canvas x:Name="PushRelabelGraphCanvas"
                    Background="#202B33"/>
        </TabItem>

        <!-- TAB 6: Edmonds-Karp -->
        <TabItem Header="Edmonds-Karp">
            <Canvas x:Name="EdmondsKarpGraphCanvas"
                    Background="#202B33"/>
        </TabItem>

    </TabControl>
</UserControl>
