<Window x:Class="time_expanded_graph.View.Dialogs.HallwaySettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Date hol"
        Width="400"
        Height="310"
        MinWidth="400"
        MinHeight="310"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#26323D">

    <Grid Margin="24,24,24,13">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="0"/>
            <RowDefinition Height="38"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Parametri hol"
                   Foreground="White"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,22"/>

        <StackPanel Margin="0,51,0,0" Grid.RowSpan="2">

            <TextBlock Text="Capacitate"
                       Foreground="White"
                       FontSize="14"
                       Margin="0,0,0,6"/>

            <TextBox x:Name="CapacityBox"
                     Text="5"
                     Height="30"
                     FontSize="14"
                     Padding="6,2"
                     Margin="0,0,0,18"/>

            <TextBlock Text="Timp traversare"
                       Foreground="White"
                       FontSize="14"
                       Margin="0,0,0,6"/>

            <TextBox x:Name="TravelTimeBox"
                     Text="1"
                     Height="30"
                     FontSize="14"
                     Padding="6,2"/>

        </StackPanel>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="142,2,0,0" Width="210">

            <Button Content="Anulează"
                    Width="100"
                    Height="34"
                    Margin="0,0,10,0"
                    Background="#607D8B"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="Cancel_Click"/>

            <Button Content="OK"
                    Width="100"
                    Height="34"
                    Background="#009C22"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="Ok_Click"/>

        </StackPanel>
    </Grid>
</Window>